# .gitignore file for MediBook project
# Tells Git which files to ignore

# Node modules directory (contains all npm packages)
node_modules/

# npm cache directory
.npm-cache/
.npm/

# Environment variables file (contains sensitive data)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# npm lock file (can be regenerated)
package-lock.json

# Dependency lock file for yarn
yarn.lock

# Build output directories
dist/
build/
.next/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# Temporary files
tmp/
temp/
*.tmp

# OS-specific files
Thumbs.db
.DS_Store
