  { patient: p3Id, doctor: d1Id, appointmentDate: daysAhead(5), timeSlot: '09:30 AM - 10:00 AM', status: 'scheduled', reason: 'Annual cardiac checkup',    symptoms: '',                        fee: 700, paymentStatus: 'pending',                                                                                       createdAt: daysAgo(1),  updatedAt: daysAgo(1)  },
