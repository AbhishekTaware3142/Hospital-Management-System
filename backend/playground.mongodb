use('Medibook');

const PWD_ADMIN   = 'Admin123';
const PWD_PATIENT = 'Patient123';
const PWD_DOCTOR  = 'Doctor123';

// ── 1. Clear and re-seed ──────────────────────────────────────
db.users.drop();
db.doctors.drop();
db.appointments.drop();
db.payments.drop();
print('✓ Cleared existing data');

