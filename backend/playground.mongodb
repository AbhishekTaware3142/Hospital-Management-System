// ── 5. Appointments ───────────────────────────────────────────
const now       = new Date();
const daysAgo   = n => new Date(now.getTime() - n * 86400000);
const daysAhead = n => new Date(now.getTime() + n * 86400000);

const apptResult = db.appointments.insertMany([
