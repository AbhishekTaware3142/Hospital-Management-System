// ── 6. Payments ───────────────────────────────────────────────
const txn = (prefix, n) => prefix + '-' + String(n).padStart(8, '0');

db.payments.insertMany([
  // Completed
  { appointment: apptIds[0],  patient: p1Id, doctor: d1Id, amount: 700, status: 'completed', method: 'UPI',         gateway: 'PhonePe',  transactionId: txn('TXN', 1001), notes: 'Chest pain evaluation',    paidAt: daysAgo(2),  createdAt: daysAgo(2),  updatedAt: daysAgo(2)  },
  { appointment: apptIds[1],  patient: p2Id, doctor: d2Id, amount: 800, status: 'completed', method: 'Card',        gateway: 'Razorpay', transactionId: txn('TXN', 1002), notes: 'Recurring headaches',      paidAt: daysAgo(4),  createdAt: daysAgo(4),  updatedAt: daysAgo(4)  },
  { appointment: apptIds[2],  patient: p3Id, doctor: d3Id, amount: 600, status: 'completed', method: 'Net Banking', gateway: 'Paytm',    transactionId: txn('TXN', 1003), notes: 'Knee pain follow-up',      paidAt: daysAgo(5),  createdAt: daysAgo(5),  updatedAt: daysAgo(5)  },
  { appointment: apptIds[9],  patient: p1Id, doctor: d1Id, amount: 700, status: 'completed', method: 'Wallet',      gateway: 'GooglePay',transactionId: txn('TXN', 1004), notes: 'Cardiac stress test',      paidAt: daysAgo(35), createdAt: daysAgo(35), updatedAt: daysAgo(35) },
  { appointment: apptIds[10], patient: p2Id, doctor: d2Id, amount: 800, status: 'completed', method: 'UPI',         gateway: 'Razorpay', transactionId: txn('TXN', 1005), notes: 'Epilepsy follow-up',       paidAt: daysAgo(40), createdAt: daysAgo(40), updatedAt: daysAgo(40) },
  { appointment: apptIds[11], patient: p4Id, doctor: d4Id, amount: 500, status: 'completed', method: 'Cash',        gateway: 'Manual',   transactionId: txn('TXN', 1006), notes: 'Child fever checkup',      paidAt: daysAgo(3),  createdAt: daysAgo(3),  updatedAt: daysAgo(3)  },
  { appointment: apptIds[12], patient: p5Id, doctor: d5Id, amount: 750, status: 'completed', method: 'UPI',         gateway: 'PhonePe',  transactionId: txn('TXN', 1007), notes: 'Skin rash treatment',      paidAt: daysAgo(6),  createdAt: daysAgo(6),  updatedAt: daysAgo(6)  },
  { appointment: apptIds[13], patient: p6Id, doctor: d6Id, amount: 450, status: 'completed', method: 'Card',        gateway: 'Razorpay', transactionId: txn('TXN', 1008), notes: 'Eye vision test',          paidAt: daysAgo(8),  createdAt: daysAgo(8),  updatedAt: daysAgo(8)  },
  // Pending
  { appointment: apptIds[3],  patient: p1Id, doctor: d2Id, amount: 800, status: 'pending',   method: 'UPI',         gateway: 'Razorpay', transactionId: null,             notes: 'Migraine consultation',    createdAt: daysAgo(7), updatedAt: daysAgo(7) },
  { appointment: apptIds[4],  patient: p2Id, doctor: d1Id, amount: 700, status: 'pending',   method: 'Card',        gateway: 'Razorpay', transactionId: null,             notes: 'Blood pressure check',     createdAt: daysAgo(9), updatedAt: daysAgo(9) },
  { appointment: apptIds[14], patient: p4Id, doctor: d5Id, amount: 750, status: 'pending',   method: 'Net Banking', gateway: 'Paytm',    transactionId: null,             notes: 'Acne treatment follow-up', createdAt: daysAgo(1), updatedAt: daysAgo(1) },
  // Refunded
  { appointment: apptIds[8],  patient: p3Id, doctor: d2Id, amount: 800, status: 'refunded',  method: 'UPI',         gateway: 'PhonePe',  transactionId: txn('TXN', 1009), notes: 'Appointment cancelled by patient', paidAt: daysAgo(6),  refundedAt: daysAgo(3),  createdAt: daysAgo(6),  updatedAt: daysAgo(3)  },
  { appointment: apptIds[16], patient: p6Id, doctor: d1Id, amount: 700, status: 'refunded',  method: 'Card',        gateway: 'Razorpay', transactionId: txn('TXN', 1010), notes: 'Doctor unavailable',              paidAt: daysAgo(12), refundedAt: daysAgo(10), createdAt: daysAgo(12), updatedAt: daysAgo(10) },
