  { patient: p1Id, doctor: d1Id, appointmentDate: daysAgo(35),  timeSlot: '09:00 AM - 09:30 AM', status: 'completed', reason: 'Cardiac stress test',       symptoms: 'Shortness of breath',     fee: 700, paymentStatus: 'completed', rating: 4,                                                                          createdAt: daysAgo(35), updatedAt: daysAgo(35) },
  { patient: p2Id, doctor: d2Id, appointmentDate: daysAgo(40),  timeSlot: '11:00 AM - 11:30 AM', status: 'completed', reason: 'Epilepsy follow-up',        symptoms: 'Occasional tremors',      fee: 800, paymentStatus: 'completed', rating: 5,                                                                          createdAt: daysAgo(40), updatedAt: daysAgo(40) },
